<h2 class="mb-4 section-title small-left-title">{{ t "Exam Timetable" }}</h2>
<div class="container mt-5">

  <div id="exam-timetable"></div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    fetch('/api/student/exams-timetable')
      .then(res => res.json())
      .then(data => {
        const container = document.getElementById('exam-timetable');
        if (!data.length) {
          container.innerHTML = '<div class="alert alert-info">No exams scheduled.</div>';
          return;
        }
        // Group exams by day
        const grouped = {};
        data.forEach(exam => {
          if (!grouped[exam.day]) grouped[exam.day] = [];
          grouped[exam.day].push(exam);
        });

        let html = `<table class="table table-bordered"><thead>
  <tr>
    <th>Date</th>
    <th>Time</th>
    <th>Module</th>
    <th>Room</th>
  </tr>
</thead><tbody>`;

        // Sort days
        const sortedDays = Object.keys(grouped).sort((a, b) => {
          const [da, ma, ya] = a.split('/').map(Number);
          const [db, mb, yb] = b.split('/').map(Number);
          return new Date(ya, ma-1, da) - new Date(yb, mb-1, db);
        });

        // Render rows with merged date cells
        sortedDays.forEach(day => {
          const exams = grouped[day].sort((a, b) => a.time.localeCompare(b.time));
          exams.forEach((exam, idx) => {
            html += `<tr>`;
            if (idx === 0) {
              html += `<td rowspan="${exams.length}">${day}</td>`;
            }
            html += `
  <td>${exam.time}</td>
  <td>${exam.module_name || exam.id_module}</td>
  <td>${exam.id_salle}</td>
</tr>`;
          });
        });

        html += '</tbody></table>';
        container.innerHTML = html;
      });
});
</script>
