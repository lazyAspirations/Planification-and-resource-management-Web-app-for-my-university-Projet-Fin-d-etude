<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/sondage.css">
    <link rel="stylesheet" href="/sondage_Ens.css">
    <link rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css'>
    <title>{{ t "Polls"}}</title>
</head>
<body>
    <nav>
        <div class="Navwrapper">
         <div class="logo"><a href="/index">ClassFlow</a></div>
       <ul class="nav-links">
         <li><a href="/index">{{ t "Time-Tables"}}</a></li>
         <li><a href="/sondage_Ens">{{ t "Polls"}}</a></li>
         <li><a href="/Exams">{{ t "Exams"}}</a></li>
         <li><a href="/evenement">{{ t "Events"}}</a></li>
       </ul>
   <div class="right-icons">
         {{!-- <div class="theme-toggle">
         <i class="fas fa-moon"></i>
         </div> --}}
         <!-- Update the notification dropdown in your nav bar -->
<div class="notification">
  <i class="fas fa-bell"></i>
  <span class="notification-count" id="notification-count">0</span>
  <ul class="notification-dropdown">
    <li class="notification-header">
      <div class="popind">
  <span>{{ t "Notifications"}}</span>
  <button id="filter-unseen-btn" style="margin-left:5px; padding:2px 10px; border-radius:5px; border:1px solid #18426d; background:#e0e0e0; color:#18426d; font-size:12px; cursor:pointer; display:box;">{{ t "Unseen"}}</button>
  </div>
  <div class="notification-actions">
    <i class="fas fa-ellipsis-v notification-menu-trigger" id="points"></i>
    <div class="notification-actions-menu">
      <a href="/NotificationEns"><i class="fas fa-list"></i> {{ t "See all"}}</a>
      <a href="#" id="mark-all-read"><i class="fas fa-check-double"></i> {{ t "Mark all as read"}}</a>
    </div>
  </div>
</li>
    <div class="notification-items" id="notification-items">
      <!-- Notifications will be loaded here dynamically -->
    </div>
  </ul>
</div>
         <div class="Navprofile">
        <i class="fas fa-user-circle"></i> <!-- FontAwesome user icon -->
        <span class="user-name">{{user.nom}} {{user.prenom}}</span>
        <ul class="profile-dropdown">
  <li>
    <a href="/userInterface">
      <i class="fas fa-cog"></i> {{ t "Settings"}} </a>
  </li>
  <li>
    <a href="/logout">
      <i class="fas fa-sign-out-alt"></i>{{ t "Sign Out"}}</a>
  </li>
</ul>
         </div>
       </div>
     </div>
   </nav>
   <div id="errMsg">
   </div>
   <div class="bod">
    <button id="creerS">{{ t "Create Poll"}}</button>

    <div id="myModal" class="modal">      
      <div class="modal-content">
        <div class="titre">
          <span class="close">&times;</span>          
          <div><button id="retour" class="hidden"><span id="arrowR"></span>&lt; {{ t "Back"}}</button>
            <h2>{{ t "Create a poll"}}</h2></div>
        </div>
        <div id="selection">
          <div id="titre"></div>
          <div class="select-wrapper">
            <select id="selectS" onchange="aa()"></select>
            <div class="custom-arrow"></div>
          </div>
          <div class="prevnext">
          <button id="previousbtn" class="skipped">
            <span class="arrowlr">←</span>
            Previous
          </button>
          <button id="next" class="skipped">
            {{ t "Next"}}
            <span class="arrowlr">→</span>
          </button>
        </div>
        </div>


        

        <div class="hidden" id="form">
          
            <label name="question">Question:</label><br>
            <input type="text" maxlength="30" minlength="1" class="qst" id="qst" name="question" placeholder="Entrer votre question" draggable="false"> 
            <label>{{ t "Options"}}:</label>
            <div class="options">
            <div class="option"  draggable="true">
              <i class="fas fa-bars"></i>
              <input type="text" maxlength="25" minlength="1" placeholder="Entrer une option" class="answer"><!--input-->
              <span onclick="remove(this)" class="removeopt">&times;</span>
            </div>
            <div class="option"  draggable="true">
              <i class="fas fa-bars"></i>
              <input type="text" maxlength="25" minlength="1" placeholder="Entrer une option" class="answer"><!--input-->
              <span onclick="remove(this)" class="removeopt">&times;</span>
            </div>
            <div id="ajoutopt"></div>
            </div>
            <div id="submit"> 
              <button id="ajouter" onclick="ajouter()">
                <span id="ajouter-btn">+</span>
                {{ t "Add option"}}
            </button>
              <button type="submit" id="submitBtn" onclick="creerPoll()">{{ t "Submit Poll"}}</button>
            </div>

          </div>  
      </div>
    </div>



    
  <div id="container"><!--hna ndiro les sondage ly yexistiw-->
  </div>
    <div id="menu">
      <div class="menu-item">Edit</div>
      <div class="menu-item">Delete</div>
    </div>

  </div> 
  <script src="/creerSondage.js"></script>
 <script src="/feforindex2.js"></script>
 <script src="/beNotification.js"></script>
</body>
</html>