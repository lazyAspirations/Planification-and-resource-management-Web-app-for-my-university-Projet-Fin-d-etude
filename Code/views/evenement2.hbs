<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Upcoming Interrogations</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/iEvenement2.css">
    <style>
        body { background: #f8fafc;
        margin-top:80px; }
        .events-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 35px;
            margin-left: 140px;
            max-width: 1100px;
        }
        .event-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.07);
            margin-bottom: 0;
            padding: 24px;
            transition: box-shadow 0.2s;
            width:100%;
        }
        .event-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.13);
        }
        .event-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #2c3e50;
        }
        .event-meta {
            color: #555;
            font-size: 1rem;
        }
        .no-events {
            text-align: center;
            margin-top: 60px;
            color: #888;
            font-size: 1.2rem;
        }
        .badge {
            display: inline-block;
            padding: 0.25em 0.4em;
            font-size: 75%;
            font-weight: 700;
            line-height: 1;
            text-align: center;
            white-space: nowrap;
            vertical-align: baseline;
            border-radius: 0.25rem;
        }
        .bg-primary {
            background-color: #044e9c;
            color: white;
        }
        .text-center{
            margin-bottom: 20px !important;
            margin-left: 30px !important;
        }
        @media (max-width: 900px) {
            .events-grid {
                grid-template-columns: 1fr;
                margin-left: 0;
            }
        }

            .small-left-title {
        width: 280px;
        font-size: 1.1rem;
        padding: 10px 18px;
        margin-left: 120px !important;
        margin-right: auto !important;
        margin-bottom: 25px !important;
        margin-top: 100px !important;
        border-radius: 8px;
        background: linear-gradient(90deg, #043d7a 0%, #007bff 100%);
        color: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        text-align: left;
        letter-spacing: 0.5px;
        font-weight: 600;
        text-shadow: 0 2px 8px rgba(0,0,0,0.08);
        display: block;
    }
    </style>
</head>
<body>

    <!-- NAV BAR -->
    <nav>
        <div class="Navwrapper">
         <div class="logo"><a href="/index2">ClassFlow</a></div>
       <ul class="nav-links">
         <li><a href="/index2">{{ t "Time-Tables" }}</a></li>
         <li><a href="/sondage">{{ t "Polls" }}</a></li>
         <li><a href="/Exams2">{{ t "Exams" }}</a></li>
         <li><a href="/evenement2">{{ t "Events" }}</a></li>
       </ul>
   <div class="right-icons">
         {{!-- <div class="theme-toggle">
         <i class="fas fa-moon"></i>
         </div> --}}
         <div class="notification">
  <i class="fas fa-bell"></i>
  <span class="notification-count" id="notification-count">0</span>
  <ul class="notification-dropdown">
    <li class="notification-header">
      <div class="popind">
  <span>{{ t "Notifications" }}</span>
  <button id="filter-unseen-btn" style="margin-left:5px; padding:2px 10px; border-radius:5px; border:1px solid #18426d; background:#e0e0e0; color:#18426d; font-size:12px; cursor:pointer; display:box;">{{ t "Unseen" }}</button>
  </div>
  <div class="notification-actions">
    <i class="fas fa-ellipsis-v notification-menu-trigger" id="points"></i>
    <div class="notification-actions-menu">
      <a href="/NotificationEtu"><i class="fas fa-list"></i>{{ t " See all" }}</a>
      <a href="#" id="mark-all-read"><i class="fas fa-check-double"></i> {{ t "Mark all as read" }}</a>
    </div>
  </div>
</li>
    <div class="notification-items" id="notification-items">
      <!-- Notifications will be loaded here dynamically -->
    </div>
  </ul>
</div>
         <div class="Navprofile">
        <i class="fas fa-user-circle"></i> <!-- FontAwesome user icon -->
        <span class="user-name">{{user.nom}} {{user.prenom}}</span>
        <ul class="profile-dropdown">
  <li>
    <a href="/userInterface2">
      <i class="fas fa-cog"></i> {{ t "Settings" }} </a>
  </li>
  <li>
    <a href="/logout">
      <i class="fas fa-sign-out-alt"></i>{{ t "Sign Out" }}</a>
  </li>
</ul>
         </div>
       </div>
     </div>
   </nav>
    <!-- END OF NAV BAR -->

    <!-- ...existing code... -->
 <div class="container py-5">
       <h2 class="mb-4 section-title small-left-title">{{ t "Upcoming Interrogations" }}</h2>
        <div id="events-container">
            <div class="no-events">
                {{ t "Loading events" }}...
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    fetch('/api/student/evenement')
        .then(res => res.json())
        .then(data => {
            const container = document.getElementById('events-container');
            if (data.sessions && data.sessions.length > 0) {
                // Create grid container
                let grid = document.createElement('div');
                grid.className = 'events-grid';
                data.sessions.forEach(ev => {
                    let card = document.createElement('div');
                    card.className = 'event-card';
                    card.innerHTML = `
                        <div class="event-title">
                            ${ev.module_name || ev.id_module} 
                            <span class="badge bg-primary ms-2">Interogation</span>
                        </div>
                        <div class="event-meta mt-2">
                            <strong>Date:</strong> ${ev.exp_intero ? new Date(ev.exp_intero).toLocaleString() : 'Not specified'}<br>
                            <strong>Day:</strong> ${ev.Jour}<br>
                            <strong>Time:</strong> ${ev.horaire}<br>
                            <strong>Room:</strong> ${ev.id_salle || 'Online'}<br>
                            <strong>Teacher:</strong> ${ev.teacher_nom ? (ev.teacher_nom + ' ' + (ev.teacher_prenom || '')) : 'Unknown'}
                        </div>
                    `;
                    grid.appendChild(card);
                });
                container.innerHTML = '';
                container.appendChild(grid);
            } else {
                container.innerHTML = `
                    <div class="no-events">
                        No upcoming interrogations found.<br>
                        Enjoy your free time! 🎉
                    </div>
                `;
            }
        })
        .catch(() => {
            document.getElementById('events-container').innerHTML = `
                <div class="no-events">Failed to load events.</div>
            `;
        });
});
</script>
<script src="/beNotification2.js"></script>
<script src="/feforindex2.js"></script>
</body>
</html>