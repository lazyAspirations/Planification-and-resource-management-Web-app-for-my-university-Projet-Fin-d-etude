<!-- BEGINING OF SELECT FOR TIMETABLE -->
<div class="timetable-controls">
  <div class="wrapper">
    <div class="select-btn" style="text-align:center;">
      <span>{{ t "My Timetable" }}</span>
      <i class="uil uil-angle-down"></i>
    </div>
    <div class="content">
      <div class="search">
        <i class="uil uil-search"></i>
        <input spellcheck="false" type="text" placeholder="Search">
      </div>
      <ul class="options">
        <!-- Options will be added dynamically -->
      </ul>
    </div>
  </div>
  <!-- Hidden original select for form submission -->
  <select id="timetable-select" style="display: none;">
    <option value="">{{ t "Loading groups" }}...</option>
  </select>
</div>
<!-- ENDING OF SELECT FOR TIMETABLE -->


<!-- BEGINING OF SHOW REQUESTS -->
<div class="form-group">
  <label>
    <input type="checkbox" class="form-control w-auto ml-auto" />
    <span class="show-requests-icon"><i class="fas fa-clipboard-list"></i></span>
    <span class="show-requests-text">{{ t "show my requests" }}</span>
  </label>
</div>
<!-- ENDING OF SHOW REQUESTS -->


