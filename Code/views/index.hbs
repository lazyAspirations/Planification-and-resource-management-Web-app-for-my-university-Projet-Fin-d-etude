<!-- BEGINING OF SMALL POPUP MENU -->
<div id="popup-menu" class="popup-menu">
  <ul>
      <li class="ajouter">{{ t "Add" }}</li>
      <li class="modifier">{{ t "Modify" }}</li>
      <li class="supprimer">{{ t "Delete" }}</li>
  </ul>
</div>
<!-- END OF SMALL POPUP MENU -->


<!-- BEGINING OF BIG POPUP MENU FOR ADD -->
<div id="big-popup-menu" class="big-popup-menu">

  <span class="close-btn">&times;</span>

  <h3>{{ t "Add a Session" }}</h3>

  <form id="add-session-form" action="/submit" method="POST" style="display: flex; gap: 20px;">
    <!-- Left Section -->
    <div style="flex: 1;">
      <div class="input-box">
        <span>{{ t "Session Frequency" }}:</span>
        <div id="radio-group" class="radio-group">
          <label>{{ t "Weekly" }}</label>
          <input type="radio" id="Hebdomadaire" name="Frequence" value="Hebdomadaire" required />
          <label>{{ t "Onetime" }}</label>
          <input type="radio" id="Exepcionnel" name="Frequence" value="Exepcionnel" required />
        </div>
      </div>

      <div>
        <label for="isOnline" class="bold-label">{{ t "Online" }}</label>
        <input type="checkbox" id="isOnline" name="isOnline">
      </div>

      <div class="input-box">
        <span>{{ t "Day:" }}</span>
        <select id="Jour" name="Jour">
          <option value="">-- {{ t "Select a day" }}--</option>
          <option value="Sunday">{{ t "Sunday" }}</option>
          <option value="Monday">{{ t "Monday" }}</option>
          <option value="Tuesday">{{ t "Tuesday" }}</option>
          <option value="Wednesday">{{ t "Wednesday" }}</option>
          <option value="Thursday">{{ t "Thursday" }}</option>
          <option value="Saturday">{{ t "Saturday" }}</option>
        </select>
      </div>

      <div class="input-box">
        <span>{{ t "Session Time" }}:</span>
        <select id="horaire" name="horaire">
          <option value="">-- Select time --</option>
          <option value="1st Session">{{ t "1st Session" }} (8:00-9:30)</option>
          <option value="2nd Session">{{ t "2nd Session" }} (9:35-11:05)</option>
          <option value="3rd Session">{{ t "3rd Session" }} (11:10-12:40)</option>
          <option value="4th Session">{{ t "4th Session" }} (12:45-14:15)</option>
          <option value="5th Session">{{ t "5th Session" }}(14:20-15:50)</option>
        </select>
      </div>

      <div class="input-box">
        <span>{{ t "Session Type" }}:</span>
        <select id="type_Seance" name="type_Seance">
          <option value="">-- {{ t "Select a type " }}--</option>
          <option value="LECTURE">{{ t "Lectur" }}</option>
          <option value="TUTORIAL">{{ t "Tutorial" }}</option>
          <option value="LAB">{{ t "Lab" }}</option>
        </select>
      </div>
    </div>

    <!-- Separator -->
    <div style="width: 1px; background-color: #ccc;"></div>

    <!-- Right Section -->
    <div style="flex: 1;">
      

      <div class="input-box">
        <span>{{ t "Module" }}:</span>
        <select id="id_module" name="id_module">
          <!-- Add module options here -->
        </select>
      </div>
      
      <div class="input-box">
    <span>{{ t "Academic Selection" }}:</span>
    <div class="selection-path" id="selection-path">
        {{ t "Start by selecting a niveau" }}
    </div>
    <div class="selection-results">
        <div class="level-options active" data-level="niveau">
            <!-- Niveau options will be loaded here -->
        </div>
        <div class="level-options" data-level="spec">
            <!-- Specialité options will be loaded here -->
        </div>
        <div class="level-options" data-level="section">
            <!-- Section options will be loaded here -->
        </div>
        <div class="level-options" data-level="group">
            <!-- Group options will be loaded here -->
        </div>
    </div>
    <input type="hidden" id="id_niveau" name="id_niveau">
    <input type="hidden" id="id_spec" name="id_spec">
    <input type="hidden" id="id_section" name="id_section">
    <input type="hidden" id="id_groupe" name="id_groupe">
</div>

      <div class="input-box">
        <span>{{ t "Room" }}:</span>
        <select id="id_salle" name="id_salle">
          <!-- Add room options here -->
        </select>
      </div>
      <button id="submit" type="submit">{{ t "Save" }}</button>
    </div>
    
  </form>
</div>
  <!-- END OF BIG POPUP MENU FOR ADD -->


<!-- BEGINING OF BIG POPUP MENU FOR DELETE -->
<div id="deleteMenu" class="big-popup-menu">
  <span class="close-btn">&times;</span>
  <h3>{{ t "Are you sure you want to delete this session" }}?</h3>
  <p id="session-delete-info"></p>
  <button id="confirm-delete" type="button">Delete</button>
  <button id="cancel-delete" type="button">Cancel</button>
</div>
<!-- END OF BIG POPUP MENU FOR DELETE -->


<!-- BEGINING OF BIG POPUP MENU FOR MODIFY -->
<div id="modifyMenu" class="big-popup-menu">
  <span class="close-btn">&times;</span>
  <h3>{{ t "Modify Session" }}</h3>
  <form id="modify-form">
      <input type="hidden" name="type_Seance">
      <div class="input-box">
          <span>{{ t "Day" }}:</span>
          <select name="Jour">
              <option value="Sunday">{{ t "Sunday" }}</option>
              <option value="Monday">{{ t "Monday" }}</option>
              <option value="Tuesday">{{ t "Tuesday" }}</option>
              <option value="Wednesday">{{ t "Wednesday" }}</option>
              <option value="Thursday">{{ t "Thursday" }}</option>
              <option value="Saturday">{{ t "Saturday" }}</option>
          </select>
      </div>
      <div class="input-box">
          <span>{{ t "Session Time" }}:</span>
          <select name="horaire">
              <option value="1st Session">{{ t "1st Session" }} (8:00-9:30)</option>
              <option value="2nd Session">{{ t "2nd Session" }} (9:35-11:05)</option>
              <option value="3rd Session">{{ t "3rd Session" }} (11:10-12:40)</option>
              <option value="4th Session">{{ t "4th Session" }} (12:45-14:15)</option>
              <option value="5th Session">{{ t "5th Session" }} (14:20-15:50)</option>
          </select>
      </div>
      <div class="input-box">
          <span>{{ t "Room" }}:</span>
          <select name="id_salle">
              <option value="">{{ t "Select a room" }}</option>
              <!-- Rooms will be populated dynamically -->
          </select>
      </div>
      <button type="submit">{{ t "Save Changes" }}</button>
  </form>
</div>
<!-- END OF BIG POPUP MENU FOR MODIFY -->

<!-- BEGINNING OF BIG POPUP MENU FOR ABSENCE -->
<div id="absenceMenu" class="big-popup-menu">
  <span class="close-btn">&times;</span>
  <h3>{{ t "Mark Absence" }}</h3>
  <form id="absence-form">
      <div class="input-box">
        <span>Reason for Absence: <span class="optional-text">*{{ t "optional" }}</span></span>
        <textarea id="absenceReason" placeholder="Enter reason for absence"></textarea>
      </div>
      <button id="confirmAbsence" type="submit">{{ t "Confirm Absence" }}</button>
  </form>
</div>
<!-- END OF BIG POPUP MENU FOR ABSENCE -->


<script src="/frontendForindex.js"></script>
<script src="/beTimeTablePopulation.js"></script>
<script src="/beModifySession.js"></script>
<script src="/beAddSession.js"></script>
<script src="/beDeleteSession.js"></script>
<script src="/beAbsence.js"></script>
<script src="/beNotification.js"></script>
   </body>
</html>

