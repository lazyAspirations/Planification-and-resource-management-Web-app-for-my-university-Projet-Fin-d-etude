<div class="container mt-4">
  <h2>Admin Requests</h2>
  <!-- Filters -->
  <div class="row mb-3">
    <div class="col">
      <input type="text" id="filter-teacher" class="form-control" placeholder="Teacher name">
    </div>
    <div class="col">
      <input type="text" id="filter-level" class="form-control" placeholder="Level">
    </div>
    <div class="col">
      <input type="text" id="filter-section" class="form-control" placeholder="Section">
    </div>
    <div class="col">
      <input type="text" id="filter-group" class="form-control" placeholder="Group">
    </div>
    <div class="col">
      <select id="filter-status" class="form-control">
        <option value="all">All</option>
        <option value="pending">Pending</option>
        <option value="1">Accepted</option>
        <option value="0">Rejected</option>
      </select>
    </div>
    <div class="col">
      <button id="apply-filters" class="btn btn-primary">Filter</button>
    </div>
  </div>
  <!-- Table -->
  <table class="table table-bordered" id="notif-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Teacher</th>
        <th>Level</th>
        <th>Section</th>
        <th>Group</th>
        <th>Type</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <!-- JS will fill this -->
    </tbody>
  </table>
</div>

<script>
async function fetchNotifications() {
  const params = new URLSearchParams({
    teacher: document.getElementById('filter-teacher').value,
    level: document.getElementById('filter-level').value,
    section: document.getElementById('filter-section').value,
    group: document.getElementById('filter-group').value,
    status: document.getElementById('filter-status').value
  });
  const res = await fetch('/api/admin/notificationsAD?' + params.toString());
  const data = await res.json();
  const tbody = document.querySelector('#notif-table tbody');
  tbody.innerHTML = '';
  data.forEach(row => {
    let statusText = 'Pending';
    if (row.status === 1 || row.status === 2) statusText = 'Accepted';
    else if (row.status === 0) statusText = 'Rejected';
    
    tbody.innerHTML += `
      <tr>
        <td>${row.DateTime || ''}</td>
        <td>${row.teacher_nom || ''} ${row.teacher_prenom || ''}</td>
        <td>${row.id_niveau || ''}</td>
        <td>${row.section_name || ''}</td>
        <td>${row.group_number || ''}</td>
        <td>${row.type_demande}</td>
        <td>${statusText}</td>
        <td>
          <button class="btn btn-success btn-sm" onclick="updateStatus(${row.id},1)" ${(row.status !== null && row.status !== -1) ? 'disabled' : ''}>Accept</button>
          <button class="btn btn-danger btn-sm" onclick="updateStatus(${row.id},0)" ${(row.status !== null && row.status !== -1) ? 'disabled' : ''}>Reject</button>
        </td>
      </tr>
    `;
});
}
async function updateStatus(id, status) {
  await fetch('/api/admin/notificationsAD/' + id + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  });
  fetchNotifications();
}
document.getElementById('apply-filters').onclick = fetchNotifications;
window.onload = fetchNotifications;
</script>
