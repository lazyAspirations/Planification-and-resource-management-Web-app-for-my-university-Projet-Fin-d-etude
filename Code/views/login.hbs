 <script>
const SECRET_CODE = "13265"; // Change this to your secret code
let inputCode = "";

document.querySelectorAll('.num').forEach(span => {
  span.addEventListener('click', function() {
    inputCode += this.dataset.num;
    if (inputCode.length === 5) {
      if (inputCode === SECRET_CODE) {
        // Show admin login form
        document.getElementById('userLoginForm').style.display = 'none';
        document.getElementById('adminStep1').style.display = 'block';
      } else {
        // Optional: shake or indicate error
        inputCode = ""; // Reset on wrong code
      }
    }
  });
});
</script>
<script>
document.getElementById('adminLoginStep1').addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const response = await fetch('/auth/admin/step1', {
    method: 'POST',
    body: JSON.stringify(Object.fromEntries(formData)),
    headers: { 'Content-Type': 'application/json' }
  });
  const data = await response.json();
  if (data.success) {
    document.getElementById('adminStep1').style.display = 'none';
    document.getElementById('adminStep2').style.display = 'block';
  } else {
    alert(data.error || 'Step 1 failed');
  }
});

document.getElementById('adminLoginStep2').addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const response = await fetch('/auth/admin/step2', {
    method: 'POST',
    body: JSON.stringify(Object.fromEntries(formData)),
    headers: { 'Content-Type': 'application/json' }
  });
  const data = await response.json();
  if (data.success) {
    window.location.href = data.redirect;
  } else {
    alert(data.error || 'Step 2 failed');
  }
});
</script>
