    <div id="container">
    </div>
    <div class="container light-style flex-grow-1 container-p-y">
        <h4 class="font-weight-bold py-3 mb-4">
            {{t "Account settings"}}
        </h4>
        <div class="card overflow-hidden">
            <div class="row no-gutters row-bordered row-border-light">
                <div class="col-md-3 pt-0">
                    <div class="list-group list-group-flush account-settings-links">
                        <a class="list-group-item list-group-item-action active" data-toggle="list"
                            href="#account-general">{{t "General"}}</a>
                        <a class="list-group-item list-group-item-action" data-toggle="list"
                            href="#settings">{{t "Settings"}}</a>
                        <a class="list-group-item list-group-item-action" data-toggle="list"
                            href="#Reset-Password">{{t "Reset Password"}}</a>
                    </div>
                </div>
                <div class="col-md-9">
                    <div class="tab-content">
                        <div class="tab-pane fade active show" id="account-general">
                            <hr class="border-light m-0">
                            <div class="card-body">
                                <p class="pAboutme">{{t "About me"}}</p>
                                <div class="form-group">
                                    <label class="form-label">{{t "Name"}}</label>
                                    <input type="text" class="form-control" value="{{user.nom}}" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">{{t "Surname"}}</label>
                                    <input type="text" class="form-control mb-1" value="{{user.prenom}}" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">{{t "Birthdate"}}</label>
                                    <input type="text" class="form-control" value="{{user.date_nec}}" readonly>
                                    </div>
                                <div class="form-group position-relative">
  <label class="form-label">{{t "Work email"}}</label>
  <div style="display: flex; align-items: center;">
    <input type="text" id="emailProInput" class="form-control mb-1" value="{{user.emailPro}}" readonly style="flex:1;">
    <span id="editEmailBtn" style="cursor:pointer; margin-left:8px; color:#18426d;">
      <i class="fas fa-pencil-alt"></i>
    </span>
    <span id="saveEmailBtn" style="display:none; cursor:pointer; margin-left:8px; color:green;">
      <i class="fas fa-check"></i>
    </span>
    <span id="cancelEmailBtn" style="display:none; cursor:pointer; margin-left:4px; color:red;">
      <i class="fas fa-times"></i>
    </span>
  </div>
  <small id="emailProMsg" class="form-text text-danger" style="display:none;"></small>
</div>
                                <p class="pAcademic">{{t "Academic Informations"}}</p>
                                 <div class="form-group">
                                    <label class="form-label">{{t "Grade"}}</label>
                                    <input type="text" class="form-control"  value="{{user.grade}}" readonly>
                                </div>
                                <div class="form-group">
  <label class="form-label">{{ t "Modules"}}</label>
  <div class="form-control" style="height: auto; min-height: 38px;" readonly>
    {{#each user.modules}}
      {{this}}{{#unless @last}}, {{/unless}}
    {{else}}
      {{t "No modules assigned"}}
    {{/each}}
  </div>
</div>
<div class="form-group">
  <label class="form-label">{{t "Sections"}}</label>
  <div class="form-control" style="height: auto; min-height: 38px;" readonly>
    {{#each user.sections}}
      {{this}}{{#unless @last}}, {{/unless}}
    {{else}}
      {{t "No sections assigned"}}
    {{/each}}
  </div>
</div>
<div class="form-group">
  <label class="form-label">{{t "Groups"}}</label>
  <div class="form-control" style="height: auto; min-height: 38px;" readonly>
    {{#each user.groups}}
      {{this}}{{#unless @last}}, {{/unless}}
    {{else}}
      {{t "No groups assigned"}}
    {{/each}}
  </div>
</div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="settings">
                            <hr class="border-light m-0">
                            <div class="card-body">
                                <p class="pPref">{{t "My Requests"}}</p>
<div class="card-body pb-2">
  <div class="form-group d-flex align-items-center">
    <div style="width:100%">
      <table class="table table-bordered table-sm" id="requestsTable">
        <thead>
  <tr>
    <th>{{t "Motif"}}</th>
    <th>{{t "Description"}}</th>
    <th>{{t "Status"}}</th>
    <th>{{t "Cancel"}}</th>
  </tr>
</thead>
        <tbody>
          <!-- Requests will be inserted here by JS -->
        </tbody>
      </table>
    </div>
  </div>
</div>

                                <p class="pPref">{{t "Preferences"}}</p>
<div class="card-body pb-2">
  <div class="form-group d-flex align-items-center">
    <label class="form-label mb-0 mr-2">{{t "Language"}}</label>
    <select id="languageSelect" class="form-control w-auto ml-auto">
      <option value="en">English</option>
      <option value="fr">Français</option>
      <option value="ar">العربية</option>
    </select>
  </div>
                            </div>
                        </div>
 </div>

                        <div class="tab-pane fade" id="Reset-Password">
    <div class="card-body pb-2">
        <form action="/auth/userInterface" method="POST" id="passwordResetForm">
            <div class="form-group">
                <label class="form-label">{{ t "Current Password"}}</label>
                <input type="password" class="form-control" name="currentPassword" id="currentPassword" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">{{ t "New Password"}}</label>
                <input type="password" class="form-control" name="newPassword" id="newPassword" 
                       pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" required>
                <div class="password-requirements mt-2">
                    <small class="text-muted">{{ t "Password must contain:"}}</small>
                    <ul class="list-unstyled">
                        <li id="length-req" class="text-danger"><i class="fas fa-times-circle"></i>{{ t " At least 8 characters"}}</li>
                        <li id="lowercase-req" class="text-danger"><i class="fas fa-times-circle"></i> {{ t "At least one lowercase letter"}}</li>
                        <li id="uppercase-req" class="text-danger"><i class="fas fa-times-circle"></i> {{ t "At least one uppercase letter"}}</li>
                        <li id="number-req" class="text-danger"><i class="fas fa-times-circle"></i> {{ t "At least one number"}}</li>
                    </ul>
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label">{{ t "Confirm New Password"}}</label>
                <input type="password" class="form-control" name="confirmPassword" id="confirmPassword" required>
                <div id="passwordMatchError" class="text-danger small mt-1"></div>
            </div>
            
            <button type="submit" class="btn btn-primary" id="changePasswordBtn" disabled>{{ t "Change Password"}}</button>
        </form>
    </div>
</div>
                   
                </div>
            </div>
        </div>
    </div>
    {{!-- <div class="text-right mt-3" style="margin-top: 0.5rem;">
        <button type="button" class="btn btn-primary">Save changes</button>&nbsp;
        <button type="button" class="btn btn-default">Cancel</button>
    </div> --}}

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Load preferences
  fetch('/api/user/preferences')
    .then(res => res.json())
    .then(data => {
      document.getElementById('languageSelect').value = data.language || 'en';
      // Only set checkbox if it exists
      const displayCheckbox = document.getElementById('displayRequestsCheckbox');
      if (displayCheckbox) displayCheckbox.checked = !!data.displayRequests;
    });

  // Save on change
  document.getElementById('languageSelect').addEventListener('change', savePrefs);
  // Only add event if checkbox exists
  const displayCheckbox = document.getElementById('displayRequestsCheckbox');
  if (displayCheckbox) displayCheckbox.addEventListener('change', savePrefs);

  function savePrefs() {
    fetch('/api/user/preferences', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        language: document.getElementById('languageSelect').value,
        displayRequests: displayCheckbox ? displayCheckbox.checked : false
      })
    }).then(() => location.reload());
  }
});
</script>
    <script src="https://code.jquery.com/jquery-1.10.2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript">
        // Additional JavaScript if needed
    </script>

    <script>
document.addEventListener('DOMContentLoaded', function() {
  const emailInput = document.getElementById('emailProInput');
  const editBtn = document.getElementById('editEmailBtn');
  const saveBtn = document.getElementById('saveEmailBtn');
  const cancelBtn = document.getElementById('cancelEmailBtn');
  const msg = document.getElementById('emailProMsg');
  let originalValue = emailInput.value;

  editBtn.onclick = function() {
    emailInput.readOnly = false;
    emailInput.focus();
    editBtn.style.display = 'none';
    saveBtn.style.display = '';
    cancelBtn.style.display = '';
  };
  cancelBtn.onclick = function() {
    emailInput.value = originalValue;
    emailInput.readOnly = true;
    editBtn.style.display = '';
    saveBtn.style.display = 'none';
    cancelBtn.style.display = 'none';
    msg.style.display = 'none';
  };
  saveBtn.onclick = function() {
    const newEmail = emailInput.value.trim();
    if (!/^[^@]+@[^@]+\.[^@]+$/.test(newEmail)) {
      msg.textContent = 'Invalid email format';
      msg.style.display = '';
      return;
    }
    fetch('/auth/update-emailPro', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ emailPro: newEmail })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        originalValue = newEmail;
        emailInput.readOnly = true;
        editBtn.style.display = '';
        saveBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
        msg.style.display = 'none';
      } else {
        msg.textContent = data.message || 'Update failed';
        msg.style.display = '';
      }
    })
    .catch(() => {
      msg.textContent = 'Server error';
      msg.style.display = '';
    });
  };
});
</script>

    <script src="/beNotification.js"></script>
</body>

</html>