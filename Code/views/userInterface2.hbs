    <script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('passwordResetForm');
    const btn = document.getElementById('changePasswordBtn');
    const matchError = document.getElementById('passwordMatchError');
    const newPassword = document.getElementById('newPassword');
    const confirmPassword = document.getElementById('confirmPassword');

    // Password validation
    function validatePassword() {
        const value = newPassword.value;
        let valid = true;
        document.getElementById('length-req').className = value.length >= 8 ? 'text-success' : 'text-danger';
        document.getElementById('lowercase-req').className = /[a-z]/.test(value) ? 'text-success' : 'text-danger';
        document.getElementById('uppercase-req').className = /[A-Z]/.test(value) ? 'text-success' : 'text-danger';
        document.getElementById('number-req').className = /\d/.test(value) ? 'text-success' : 'text-danger';
        if (
            value.length < 8 ||
            !/[a-z]/.test(value) ||
            !/[A-Z]/.test(value) ||
            !/\d/.test(value)
        ) {
            valid = false;
        }
        btn.disabled = !valid || newPassword.value !== confirmPassword.value;
    }

    newPassword.addEventListener('input', validatePassword);
    confirmPassword.addEventListener('input', function() {
        if (newPassword.value !== confirmPassword.value) {
            matchError.textContent = "Passwords do not match.";
            btn.disabled = true;
        } else {
            matchError.textContent = "";
            validatePassword();
        }
    });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        btn.disabled = true;
        fetch('/auth/userInterface2', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                currentPassword: form.currentPassword.value,
                newPassword: form.newPassword.value,
                confirmPassword: form.confirmPassword.value
            })
        })
        .then(res => res.json())
        .then(data => {
            btn.disabled = false;
            if (data.message) {
                alert(data.message);
                form.reset();
            } else if (data.error) {
                alert(data.error);
            }
        })
        .catch(() => {
            btn.disabled = false;
            alert('An error occurred. Please try again.');
        });
    });
});
</script>

<script>document.addEventListener('DOMContentLoaded', function() {
  const sectionGroupDiv = document.getElementById('sectionGroupDisplay');
  if (sectionGroupDiv) {
    fetch('/api/student/section-group')
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          sectionGroupDiv.textContent = "Not specified";
        } else {
          sectionGroupDiv.textContent = `${data.section_name} - G${data.group_number}`;
        }
      })
      .catch(() => {
        sectionGroupDiv.textContent = "Not specified";
      });
  }
});</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const emailInput = document.getElementById('emailProInput');
  const editBtn = document.getElementById('editEmailBtn');
  const saveBtn = document.getElementById('saveEmailBtn');
  const cancelBtn = document.getElementById('cancelEmailBtn');
  const msg = document.getElementById('emailProMsg');
  let originalValue = emailInput.value;

  editBtn.onclick = function() {
    emailInput.readOnly = false;
    emailInput.focus();
    editBtn.style.display = 'none';
    saveBtn.style.display = '';
    cancelBtn.style.display = '';
  };
  cancelBtn.onclick = function() {
    emailInput.value = originalValue;
    emailInput.readOnly = true;
    editBtn.style.display = '';
    saveBtn.style.display = 'none';
    cancelBtn.style.display = 'none';
    msg.style.display = 'none';
  };
  saveBtn.onclick = function() {
    const newEmail = emailInput.value.trim();
    if (!/^[^@]+@[^@]+\.[^@]+$/.test(newEmail)) {
      msg.textContent = 'Invalid email format';
      msg.style.display = '';
      return;
    }
    fetch('/auth/update-emailPro-student', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ emailPro: newEmail })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        originalValue = newEmail;
        emailInput.readOnly = true;
        editBtn.style.display = '';
        saveBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
        msg.style.display = 'none';
      } else {
        msg.textContent = data.message || 'Update failed';
        msg.style.display = '';
      }
    })
    .catch(() => {
      msg.textContent = 'Server error';
      msg.style.display = '';
    });
  };
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Load preferences
  fetch('/api/student/preferences')
    .then(res => res.json())
    .then(data => {
      document.getElementById('languageSelect').value = data.language || 'en';
      const displayCheckbox = document.getElementById('displayRequestsCheckbox');
      if (displayCheckbox) displayCheckbox.checked = !!data.displayRequests;
    });

  // Save on change
  document.getElementById('languageSelect').addEventListener('change', savePrefs);
  const displayCheckbox = document.getElementById('displayRequestsCheckbox');
  if (displayCheckbox) displayCheckbox.addEventListener('change', savePrefs);

  function savePrefs() {
    fetch('/api/student/preferences', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        language: document.getElementById('languageSelect').value,
        displayRequests: displayCheckbox ? displayCheckbox.checked : false
      })
    }).then(() => location.reload());
  }
});
</script>
